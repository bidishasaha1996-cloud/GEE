import io
import math
import base64

from PIL import Image, ImageDraw
from google.colab import files
from IPython.display import display, HTML

# -------------------------
# SETTINGS
# -------------------------
OUTPUT_GIF_NAME = "before_after_juxtapose_fixed.gif"

# Keep None to preserve maximum possible quality without forced resizing
# Set a number like 1600 only if you want to cap output width
MAX_OUTPUT_WIDTH = None

FPS = 20
CYCLE_DURATION_SEC = 4.0
LINE_WIDTH = 2
HOLD_AT_EDGES_FRAMES = 4

PAD_COLOR = (0, 0, 0)   # used only if images have different aspect ratios
GIF_COLORS = 255


# -------------------------
# HELPERS
# -------------------------
def prepare_image_no_upscale(img, canvas_w, canvas_h, pad_color=(0, 0, 0)):
    """
    Fit image inside canvas without cropping and without upscaling.
    Pads if needed so both images share identical dimensions.
    """
    img = img.convert("RGB")
    img_copy = img.copy()
    img_copy.thumbnail((canvas_w, canvas_h), Image.LANCZOS)

    canvas = Image.new("RGB", (canvas_w, canvas_h), pad_color)
    x = (canvas_w - img_copy.width) // 2
    y = (canvas_h - img_copy.height) // 2
    canvas.paste(img_copy, (x, y))
    return canvas


def build_divider_positions(width, fps=20, cycle_duration=4.0, hold_frames=0):
    total_frames = max(2, int(fps * cycle_duration))
    half = max(2, total_frames // 2)

    def ease_in_out(t):
        return 0.5 * (1 - math.cos(math.pi * t))

    forward = []
    for i in range(half):
        t = i / (half - 1)
        x = int(ease_in_out(t) * width)
        forward.append(x)

    backward = list(reversed(forward[1:-1]))
    positions = forward + backward

    if hold_frames > 0:
        positions = [0] * hold_frames + positions[:half] + [width] * hold_frames + positions[half:]

    return positions


def make_juxtapose_frame(before_img, after_img, divider_x, line_width=2):
    """
    Left = before, right = after, with thin white divider.
    """
    w, h = before_img.size
    divider_x = max(0, min(w, divider_x))

    frame = before_img.copy()

    if divider_x < w:
        right_part = after_img.crop((divider_x, 0, w, h))
        frame.paste(right_part, (divider_x, 0))

    draw = ImageDraw.Draw(frame)
    draw.rectangle(
        [divider_x - line_width // 2, 0, divider_x + line_width // 2, h],
        fill=(255, 255, 255)
    )

    return frame


def build_master_palette(before_img, after_img, positions, line_width, sample_count=8):
    """
    Build one global palette from a few representative frames,
    so colours remain stable across the entire GIF.
    """
    w, h = before_img.size

    if len(positions) <= sample_count:
        sample_positions = positions
    else:
        idxs = [round(i * (len(positions) - 1) / (sample_count - 1)) for i in range(sample_count)]
        sample_positions = [positions[i] for i in idxs]

    strip = Image.new("RGB", (w * len(sample_positions), h))

    for i, x in enumerate(sample_positions):
        sample_frame = make_juxtapose_frame(before_img, after_img, x, line_width=line_width)
        strip.paste(sample_frame, (i * w, 0))

    # One shared palette for all frames
    master_palette = strip.quantize(
        colors=GIF_COLORS,
        method=Image.MEDIANCUT,
        dither=Image.Dither.NONE
    )
    return master_palette


def convert_with_master_palette(rgb_frame, master_palette):
    return rgb_frame.quantize(
        palette=master_palette,
        dither=Image.Dither.NONE
    )


# -------------------------
# STEP 1: UPLOAD 2 IMAGES
# -------------------------
print("Upload EXACTLY 2 images: first = BEFORE, second = AFTER")
uploaded = files.upload()

uploaded_names = list(uploaded.keys())
if len(uploaded_names) != 2:
    raise ValueError(f"Please upload exactly 2 images. You uploaded {len(uploaded_names)} file(s).")

before_name = uploaded_names[0]
after_name = uploaded_names[1]

print(f"\nBefore image: {before_name}")
print(f"After image : {after_name}")


# -------------------------
# STEP 2: LOAD IMAGES
# -------------------------
before_raw = Image.open(io.BytesIO(uploaded[before_name])).convert("RGB")
after_raw = Image.open(io.BytesIO(uploaded[after_name])).convert("RGB")

# Use the smaller common canvas to avoid upscaling either image
canvas_w = min(before_raw.width, after_raw.width)
canvas_h = min(before_raw.height, after_raw.height)

# Optional cap, but never upscale
if MAX_OUTPUT_WIDTH is not None and canvas_w > MAX_OUTPUT_WIDTH:
    scale = MAX_OUTPUT_WIDTH / canvas_w
    canvas_w = int(canvas_w * scale)
    canvas_h = int(canvas_h * scale)

before_img = prepare_image_no_upscale(before_raw, canvas_w, canvas_h, pad_color=PAD_COLOR)
after_img = prepare_image_no_upscale(after_raw, canvas_w, canvas_h, pad_color=PAD_COLOR)


# -------------------------
# STEP 3: BUILD FRAMES
# -------------------------
positions = build_divider_positions(
    width=canvas_w,
    fps=FPS,
    cycle_duration=CYCLE_DURATION_SEC,
    hold_frames=HOLD_AT_EDGES_FRAMES
)

rgb_frames = []
for x in positions:
    rgb_frames.append(
        make_juxtapose_frame(
            before_img,
            after_img,
            divider_x=x,
            line_width=LINE_WIDTH
        )
    )

# Build one stable palette for all frames
master_palette = build_master_palette(
    before_img,
    after_img,
    positions,
    line_width=LINE_WIDTH,
    sample_count=8
)

gif_frames = [convert_with_master_palette(frame, master_palette) for frame in rgb_frames]


# -------------------------
# STEP 4: SAVE GIF
# -------------------------
frame_duration_ms = int(1000 / FPS)

gif_frames[0].save(
    OUTPUT_GIF_NAME,
    save_all=True,
    append_images=gif_frames[1:],
    duration=frame_duration_ms,
    loop=0,
    optimize=False,   # IMPORTANT: reduces flicker/shimmer
    disposal=2        # IMPORTANT: cleaner frame redraw
)

print(f"\nGIF saved as: {OUTPUT_GIF_NAME}")


# -------------------------
# STEP 5: PREVIEW IN COLAB
# -------------------------
with open(OUTPUT_GIF_NAME, "rb") as f:
    gif_b64 = base64.b64encode(f.read()).decode("utf-8")

display(HTML(f"""
<div style="max-width:900px; margin:20px auto; text-align:center;">
  <p style="font-family:Arial; color:#666;">Preview (browser preview may still look slightly harsher than downloaded file)</p>
  <img src="data:image/gif;base64,{gif_b64}" style="max-width:100%; height:auto; border-radius:8px;" />
</div>
"""))


# -------------------------
# STEP 6: AUTO-DOWNLOAD GIF
# -------------------------
files.download(OUTPUT_GIF_NAME)
